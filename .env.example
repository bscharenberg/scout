# Scout Environment Variables
# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# ---
# REQUIRED (v1)
# ---

# Anthropic API key - get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# ---
# REQUIRED (v2 - API layer)
# ---

# Environment: development, staging, production
ENVIRONMENT=development

# Port for the FastAPI server
PORT=8000

# Secret key for signing session tokens
SECRET_KEY=your_secret_key_here

# ---
# CRM INTEGRATION (v2 - optional)
# ---

# HubSpot private app token (read-only scopes: crm.objects.deals.read, crm.objects.contacts.read, crm.objects.companies.read)
HUBSPOT_ACCESS_TOKEN=your_hubspot_token_here

# Salesforce connected app credentials (read-only profile recommended)
SALESFORCE_CLIENT_ID=your_salesforce_client_id
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret
SALESFORCE_USERNAME=your_salesforce_username
SALESFORCE_DOMAIN=login  # or your custom domain e.g. test for sandbox

# ---
# IDENTITY PROVIDER (v2 - authentication)
# ---

# Okta or Azure AD OIDC settings for SSO
OIDC_CLIENT_ID=your_oidc_client_id
OIDC_CLIENT_SECRET=your_oidc_client_secret
OIDC_ISSUER_URL=https://your-org.okta.com/oauth2/default

# ---
# VECTOR STORE (v2 - RAG pipeline)
# ---

# LanceDB local path (default) or Pinecone for hosted
LANCEDB_PATH=./data/lancedb
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_ENVIRONMENT=your_pinecone_environment
# PINECONE_INDEX_NAME=scout

# ---
# LOGGING (v2)
# ---

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: external log sink (e.g. Datadog, Papertrail)
# LOG_SINK_URL=your_log_sink_url
